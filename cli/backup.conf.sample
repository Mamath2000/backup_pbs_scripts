# ===========================================================================
# CONFIGURATION PBS (Proxmox Backup Server) - EXEMPLE
# ===========================================================================
# Mode d'exécution: apt ou docker
PBS_CLIENT_MODE="docker"
# PBS_CLIENT_MODE="apt"

# Référentiel PBS (ex: user@pbs@pbs.local:datastore)
PBS_REPOSITORY="demo@pbs@demo.local:backup"
PBS_PASSWORD="demo-password"
PBS_FINGERPRINT="00:11:22:33:44:55:66:77:88:99:aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99:aa:bb:cc:dd:ee:ff"
PBS_NAMESPACE="Hosts"

# ===========================================================================
# CONFIGURATION MQTT / HOME ASSISTANT (optionnel)
# ===========================================================================
# MQTT configuration: only the host is required; other values have sensible defaults
# MQTT_ENABLED=false  # default: false
MQTT_HOST="mqtt.demo.local"
# MQTT_PORT="1883"    # default: "1883"
# MQTT_USER=""        # default: empty
# MQTT_PASSWORD=""    # default: empty